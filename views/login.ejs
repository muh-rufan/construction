<%- include('partials/header') %>
<%- include('partials/navbar') %>

<section class="py-5">
  <div class="container">
    <h1 class="mb-4 text-center">Login</h1>
    <p class="text-center text-muted mb-4">Choose how you want to sign in</p>

    <div class="row justify-content-center g-4">
      <!-- User Login -->
      <div class="col-md-5">
        <div class="card shadow-sm h-100">
          <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-person me-2"></i>User Login</h5>
          </div>
          <div class="card-body">
            <% if (success && loginType === 'user') { %>
              <div class="alert alert-success"><%= success %></div>
            <% } %>
            <% if (error && loginType === 'user') { %>
              <div class="alert alert-danger"><%= error %></div>
            <% } %>
            <% if (info && loginType === 'user') { %>
              <div class="alert alert-info"><%= info %></div>
            <% } %>
            <form method="POST" action="/login">
              <div class="mb-3">
                <label class="form-label">Email</label>
                <input name="email" type="email" class="form-control" required />
              </div>
              <div class="mb-3">
                <label class="form-label">Password</label>
                <input name="password" type="password" class="form-control" required />
              </div>
              <button type="submit" class="btn btn-warning w-100">Login</button>
              <% if (showResend && resendEmail && loginType === 'user') { %>
                <div class="mt-3 text-center">
                  <form method="POST" action="/auth/resend-verification" class="d-inline">
                    <input type="hidden" name="email" value="<%= resendEmail %>" />
                    <button type="submit" class="btn btn-link p-0">Resend Verification Email</button>
                  </form>
                </div>
              <% } %>
              <p class="mt-3 mb-0 small text-center">
                Don't have an account?
                <a href="/register">Register now</a>
              </p>
            </form>
          </div>
        </div>
      </div>

      <!-- Admin Login -->
      <div class="col-md-5">
        <div class="card shadow-sm h-100">
          <div class="card-header bg-dark text-white">
            <h5 class="mb-0"><i class="bi bi-shield-lock me-2"></i>Admin Login</h5>
          </div>
          <div class="card-body">
            <% if (error && loginType === 'admin') { %>
              <div class="alert alert-danger"><%= error %></div>
            <% } %>
            <form method="POST" action="/admin/login">
              <div class="mb-3">
                <label class="form-label">Username</label>
                <input name="username" type="text" class="form-control" required />
              </div>
              <div class="mb-3">
                <label class="form-label">Password</label>
                <input name="password" type="password" class="form-control" required />
              </div>
              <button type="submit" class="btn btn-warning w-100">Login</button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>

