<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<section class="py-5">
  <div class="container">
    <h1 class="mb-4">Notifications</h1>
    <% if (notifications && notifications.length) { %>
      <div class="list-group">
        <% notifications.forEach(function(n) { %>
          <div class="list-group-item d-flex justify-content-between align-items-start">
            <div>
              <h5 class="<%= n.is_read ? 'text-muted' : '' %>"><%= n.title %></h5>
              <p class="mb-1"><%= n.message %></p>
              <small class="text-muted">
                <%= n.created_at.toDateString ? n.created_at.toDateString() : n.created_at %>
              </small>
            </div>
            <% if (!n.is_read) { %>
              <form method="POST" action="/notifications/mark-read/<%= n.user_notification_id %>">
                <button class="btn btn-sm btn-outline-secondary">Mark as read</button>
              </form>
            <% } else { %>
              <span class="badge bg-secondary">Read</span>
            <% } %>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <p class="text-muted">No notifications.</p>
    <% } %>
  </div>
</section>

<%- include('../partials/footer') %>
